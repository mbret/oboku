# Dev only (loaded by `vite`, never by `vite build`).
#
# Live replication of several collections needs more concurrent connections
# than the browser allows per origin over HTTP/1. Production solves this with
# HTTP/2; local dev has none, so the dev-proxy (docker-compose.dev.yml) exposes
# extra origins that all forward to the API. The primary origin is the API
# itself (VITE_API_URL, :3000); these are the additional ones.
VITE_API_URL_2=http://localhost:5985
VITE_API_URL_3=http://localhost:5986
VITE_API_URL_4=http://localhost:5987
